{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      // Go is tracked in two managers — the go.mod `go` directive and the mise `go`
      // pin — so group both into one "Go toolchain" PR. minimumGroupSize: 2 keeps a
      // lone bump (only one side moving) as a normal individual PR rather than a
      // singleton group. Inherited org-wide via default.json; no-op in non-Go repos.
      description: "Group the Go toolchain (go.mod directive + mise pin) into one PR",
      matchManagers: ["mise", "gomod"],
      matchDepNames: ["go"],
      matchFileNames: [".mise/config.toml", "go.mod"],
      groupName: "Go toolchain",
      groupSlug: "go-toolchain",
      minimumGroupSize: 2,
    },
    {
      // Rust is pinned only in mise (Cargo.toml `rust-version` isn't Renovate-tracked,
      // and there's no rust-toolchain.toml), so this is single-source — the rule just
      // gives kopiur/drm-exporter a consistent "Rust toolchain" PR. No minimumGroupSize:
      // a one-source toolchain can never reach 2, which would suppress the group name.
      description: "Name the Rust toolchain (mise pin) bump consistently",
      matchManagers: ["mise"],
      matchDepNames: ["rust"],
      matchFileNames: [".mise/config.toml"],
      groupName: "Rust toolchain",
      groupSlug: "rust-toolchain",
    },
    {
      // Node is pinned only in mise (no .nvmrc / package.json engines) — single-source,
      // same as Rust: consistent "Node toolchain" PR name, no minimumGroupSize.
      description: "Name the Node toolchain (mise pin) bump consistently",
      matchManagers: ["mise"],
      matchDepNames: ["node"],
      matchFileNames: [".mise/config.toml"],
      groupName: "Node toolchain",
      groupSlug: "node-toolchain",
    },
  ],
}
