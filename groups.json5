{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "GitHub Actions Group",
      matchManagers: ["github-actions"],
      groupName: "github-actions",
      minimumReleaseAge: "3 days",
    },
    // Catch-all for mise-managed dev tooling (linters, formatters, CLIs). Kept
    // above the language-toolchain rules so their more specific groupName wins
    // for go/rust/node (later packageRules override earlier ones).
    {
      description: "Mise Tools Group",
      matchManagers: ["mise"],
      groupName: "mise tools",
      groupSlug: "mise-tools",
    },
    {
      description: "Go Toolchain Group",
      matchManagers: ["mise", "gomod"],
      matchDepNames: ["go"],
      matchFileNames: [".mise/config.toml", "go.mod"],
      groupName: "Go toolchain",
      groupSlug: "go-toolchain",
    },
    {
      description: "Rust Toolchain Group",
      matchManagers: ["mise"],
      matchDepNames: ["rust"],
      matchFileNames: [".mise/config.toml"],
      groupName: "Rust toolchain",
      groupSlug: "rust-toolchain",
    },
    {
      description: "Node Toolchain Group",
      matchManagers: ["mise"],
      matchDepNames: ["node"],
      matchFileNames: [".mise/config.toml"],
      groupName: "Node toolchain",
      groupSlug: "node-toolchain",
    },
  ],
}
